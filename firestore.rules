rules_version = '2';

// ===============================================================
// hawaa.in — Firestore security rules (project hawaa-air-27548)
//
// Assumed Data Model
// ===============================================================
//
// Collection: supportTickets (contact form, anonymous create-only)
//   - name: string 1-100 | email: valid email | message: string 1-5000
//   - page: string <=200 | createdAt: server time
//
// Collection: newsletterSubscribers (footer form, doc ID = encoded email)
//   - email: valid email | createdAt: server time
//
// Collection: web_users (website profile docs — deliberately separate
// from the server-managed `users` and `device_owners` collections used
// by the device backend, which remain client-inaccessible)
// Document ID: {userId} — always equal to the Firebase Auth UID
//   - uid: string (== auth.uid, immutable)
//   - createdAt: timestamp (server time on create, immutable)
//   - lastLoginAt: timestamp (server time, refreshed on sign-in)
//   - displayName: string (optional, 1-100)
//   - email: string (optional, valid email, immutable)
//   - phone: string (optional, E.164, immutable)
//   - photoURL: string (optional, provider avatar URL or small data: URI)
//
// Collection: reviews (product reviews, sign-in + moderation model)
//   - uid: string (== auth.uid on create, immutable)
//   - name: string 1-50 (author-chosen public display name)
//   - rating: int 1-5 | title: string 1-100 | content: string 1-2000
//   - status: 'pending' on create; only console/admin flips to 'approved';
//     only approved docs are publicly readable (owners can read their own)
//   - verified: bool, false on create (admin marks verified purchases)
//   - helpful: int, 0 on create; +1 only via vote batch
//   - createdAt: timestamp (server time, immutable)
//
// Collection: review_votes — one permanent Helpful vote per user per
// review. Document ID: {uid}_{reviewId}; created atomically with the
// helpful increment.
//
// All other collections (incl. device backend's users, device_owners):
// no client access.
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function validEmail(e) {
      return e is string && e.size() >= 5 && e.size() <= 320 && e.matches('.+@.+\\..+');
    }

    function isServerTime(t) {
      return t is timestamp && t == request.time;
    }

    function isValidPhone(phone) {
      return phone is string && phone.matches("^\\+[0-9]{8,15}$");
    }

    function isValidDisplayName(name) {
      return name is string && name.size() >= 1 && name.size() <= 100;
    }

    // Profile photo: either a provider avatar URL (https) or a small
    // client-compressed data: URI. Bounded so a single field can never
    // approach Firestore's 1 MB document ceiling.
    function isValidPhotoURL(url) {
      return url is string && url.size() >= 1 && url.size() <= 900000;
    }

    // ===============================================================
    // supportTickets — contact form on support.html (anonymous)
    // ===============================================================
    match /supportTickets/{ticketId} {
      allow create: if
        request.resource.data.keys().hasOnly(['name', 'email', 'message', 'page', 'createdAt']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() >= 1 &&
        request.resource.data.name.size() <= 100 &&
        validEmail(request.resource.data.email) &&
        request.resource.data.message is string &&
        request.resource.data.message.size() >= 1 &&
        request.resource.data.message.size() <= 5000 &&
        request.resource.data.page is string &&
        request.resource.data.page.size() <= 200 &&
        isServerTime(request.resource.data.createdAt);
      allow read, update, delete: if false;
    }

    // ===============================================================
    // newsletterSubscribers — footer form (doc ID = encoded email)
    // ===============================================================
    match /newsletterSubscribers/{subscriberId} {
      allow create: if
        request.resource.data.keys().hasOnly(['email', 'createdAt']) &&
        validEmail(request.resource.data.email) &&
        isServerTime(request.resource.data.createdAt);
      allow read, update, delete: if false;
    }

    // ===============================================================
    // Domain Validators — web_users
    // ===============================================================

    function isValidNewUser(data, userId) {
      return data.keys().hasAll(['uid', 'createdAt', 'lastLoginAt']) &&
        data.keys().hasOnly(['uid', 'createdAt', 'lastLoginAt', 'displayName', 'email', 'phone', 'photoURL']) &&
        data.uid == userId &&
        isServerTime(data.createdAt) &&
        isServerTime(data.lastLoginAt) &&
        (!('displayName' in data) || isValidDisplayName(data.displayName)) &&
        (!('email' in data) || validEmail(data.email)) &&
        (!('phone' in data) || isValidPhone(data.phone)) &&
        (!('photoURL' in data) || isValidPhotoURL(data.photoURL));
    }

    // Updates may only touch lastLoginAt, displayName and photoURL; identity
    // fields (uid, createdAt, email, phone) are immutable.
    function isValidUserUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['lastLoginAt', 'displayName', 'photoURL']) &&
        isServerTime(request.resource.data.lastLoginAt) &&
        (!('displayName' in request.resource.data) ||
          isValidDisplayName(request.resource.data.displayName)) &&
        (!('photoURL' in request.resource.data) ||
          isValidPhotoURL(request.resource.data.photoURL));
    }

    // ===============================================================
    // web_users — private profile documents, owner-only access
    // ===============================================================
    match /web_users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidNewUser(request.resource.data, userId);
      allow update: if isOwner(userId) && isValidUserUpdate();
      allow delete: if false;
    }

    // ===============================================================
    // Domain Validators — reviews
    // ===============================================================

    // Full-document validation on review create. New reviews always
    // arrive as status 'pending' (moderated in the console), verified
    // is forced to false, and the helpful counter starts at zero.
    function isValidNewReview(data) {
      return data.keys().hasAll(['uid', 'name', 'rating', 'title', 'content', 'status', 'verified', 'helpful', 'createdAt']) &&
        data.keys().hasOnly(['uid', 'name', 'rating', 'title', 'content', 'status', 'verified', 'helpful', 'createdAt']) &&
        data.uid == request.auth.uid &&
        data.name is string && data.name.size() >= 1 && data.name.size() <= 50 &&
        data.rating is int && data.rating >= 1 && data.rating <= 5 &&
        data.title is string && data.title.size() >= 1 && data.title.size() <= 100 &&
        data.content is string && data.content.size() >= 1 && data.content.size() <= 2000 &&
        data.status == 'pending' &&
        data.verified == false &&
        data.helpful is int && data.helpful == 0 &&
        isServerTime(data.createdAt);
    }

    // A "Helpful" vote: the ONLY change is helpful going up by exactly 1,
    // and the caller's vote-tracking document must be created in the same
    // batch (getAfter) while not existing beforehand — one vote per user
    // per review, no counter looping. The getAfter check on the review
    // itself constrains the POST-batch value, so stacking multiple
    // increment writes in one batch cannot inflate the counter past +1.
    function isValidHelpfulVote(reviewId) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['helpful']) &&
        request.resource.data.helpful == resource.data.helpful + 1 &&
        getAfter(/databases/$(database)/documents/reviews/$(reviewId)).data.helpful == resource.data.helpful + 1 &&
        !exists(/databases/$(database)/documents/review_votes/$(request.auth.uid + '_' + reviewId)) &&
        getAfter(/databases/$(database)/documents/review_votes/$(request.auth.uid + '_' + reviewId)).data.uid == request.auth.uid;
    }

    // Vote-tracking document validation: key must be {caller-uid}_{reviewId},
    // the review must exist, and the schema is fixed.
    function isValidNewVote(data, voteId) {
      return data.keys().hasAll(['uid', 'reviewId', 'createdAt']) &&
        data.keys().hasOnly(['uid', 'reviewId', 'createdAt']) &&
        data.uid == request.auth.uid &&
        data.reviewId is string && data.reviewId.size() >= 1 && data.reviewId.size() <= 40 &&
        voteId == request.auth.uid + '_' + data.reviewId &&
        exists(/databases/$(database)/documents/reviews/$(data.reviewId)) &&
        isServerTime(data.createdAt);
    }

    // ===============================================================
    // reviews — sign-in required to write, moderated before public
    // ===============================================================
    match /reviews/{reviewId} {
      // Approved reviews are public; authors can also see their own
      // (e.g. pending ones listed on the account page).
      allow read: if resource.data.status == 'approved' ||
        (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && isValidNewReview(request.resource.data);
      allow update: if isAuthenticated() && isValidHelpfulVote(reviewId);
      allow delete: if false;
    }

    // ===============================================================
    // review_votes — one Helpful vote per user per review
    // ===============================================================
    match /review_votes/{voteId} {
      // Users may only read their own votes (used to mark voted reviews).
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidNewVote(request.resource.data, voteId);
      allow update, delete: if false;
    }

    // ===============================================================
    // Domain Validators — orders (Cash on Delivery)
    //
    // Fixed catalog prices are enforced here so a tampered client can
    // never change what an order costs:
    //   purifier one-time ₹5999 | purifier subscription ₹5499 |
    //   replacement filter ₹1499 | GST 18% (round half-up) | free delivery
    // ===============================================================

    function isValidOrderAddress(a) {
      return a is map &&
        a.keys().hasAll(['name', 'phone', 'line1', 'city', 'state', 'pincode']) &&
        a.keys().hasOnly(['name', 'phone', 'line1', 'line2', 'city', 'state', 'pincode']) &&
        a.name is string && a.name.size() >= 1 && a.name.size() <= 100 &&
        a.phone is string && a.phone.matches('^\\+91[6-9][0-9]{9}$') &&
        a.line1 is string && a.line1.size() >= 1 && a.line1.size() <= 200 &&
        (!('line2' in a) || (a.line2 is string && a.line2.size() >= 1 && a.line2.size() <= 200)) &&
        a.city is string && a.city.size() >= 1 && a.city.size() <= 100 &&
        a.state is string && a.state.size() >= 1 && a.state.size() <= 100 &&
        a.pincode is string && a.pincode.matches('^[1-9][0-9]{5}$');
    }

    function isValidQty(q) {
      return q is int && q >= 0 && q <= 10;
    }

    function isValidNewOrder(data) {
      return data.keys().hasAll(['uid', 'qtyPurifierOnetime', 'qtyPurifierSubscribe', 'qtyFilter', 'subtotal', 'gst', 'total', 'address', 'paymentMethod', 'status', 'createdAt']) &&
        data.keys().hasOnly(['uid', 'qtyPurifierOnetime', 'qtyPurifierSubscribe', 'qtyFilter', 'filterInterval', 'subtotal', 'gst', 'total', 'address', 'paymentMethod', 'status', 'createdAt']) &&
        data.uid == request.auth.uid &&
        isValidQty(data.qtyPurifierOnetime) &&
        isValidQty(data.qtyPurifierSubscribe) &&
        isValidQty(data.qtyFilter) &&
        (data.qtyPurifierOnetime + data.qtyPurifierSubscribe + data.qtyFilter) >= 1 &&
        (!('filterInterval' in data) || (data.filterInterval is int && data.filterInterval in [5, 6])) &&
        data.subtotal is int &&
        data.subtotal == data.qtyPurifierOnetime * 5999 + data.qtyPurifierSubscribe * 5499 + data.qtyFilter * 1499 &&
        data.gst is int &&
        data.gst == (data.subtotal * 18 + 50) / 100 &&
        data.total is int &&
        data.total == data.subtotal + data.gst &&
        isValidOrderAddress(data.address) &&
        data.paymentMethod == 'cod' &&
        data.status == 'placed' &&
        isServerTime(data.createdAt);
    }

    // ===============================================================
    // orders — sign-in required; owners read their own; status changes
    // happen only from the console / privileged server code
    // ===============================================================
    match /orders/{orderId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidNewOrder(request.resource.data);
      allow update, delete: if false;
    }

    // ===============================================================
    // aqi — public CPCB air-quality snapshot (aqi/latest), written
    // only by the scheduled Cloud Function via the Admin SDK (which
    // bypasses these rules). Clients read, never write.
    // ===============================================================
    match /aqi/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ===============================================================
    // Default deny: everything not matched above is inaccessible.
    // This keeps the device backend's collections (users, device_owners)
    // server-only.
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
